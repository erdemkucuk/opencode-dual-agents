{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      }
    }
  },
  "model": "google/gemini-3-flash-preview",
  "mcp": {
    "agent2": {
      "type": "local",
      "enabled": true,
      "command": ["opencode-mcp"],
      "environment": {
        "OPENCODE_BASE_URL": "http://agent2:4096"
      }
    }
  }
}
